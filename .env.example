# Django settings
DJANGO_SETTINGS_MODULE=server.settings.base
SECRET_KEY=change-me-to-a-random-string
DEBUG=True

# Server
ALLOWED_HOSTS=*
SERVER_IP=127.0.0.1
SERVER_PORT=8000

# Google Maps (optional, used for distance calculations and live map)
GOOGLE_MAPS_API_KEY=

# Email (SMTP) – set EMAIL_BACKEND to django.core.mail.backends.smtp.EmailBackend for real email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@tapawingohike.nl
